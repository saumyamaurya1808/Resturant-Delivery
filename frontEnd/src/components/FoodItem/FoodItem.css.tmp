.food-item{
    width: 100%;
    max-width: 260px;
    margin: auto;
    border-radius: 20px;
    overflow: hidden;
    background: #ffffff;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    animation: fadeIn 0.8s ease;
    cursor: pointer;
}

.food-item:hover{
    transform: translateY(-8px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.15);
}

.food-item-img-container{
    position: relative;
    overflow: hidden;
}

.food-item-image{
    width: 100%;
    height: 250px;
    object-fit: cover;
    transition: transform 0.4s ease;
}

.food-item:hover .food-item-image{
    transform: scale(1.08);
}

/* Add Button */
.add-btn{
    position: absolute;
    bottom: 15px;
    right: 15px;
    border: none;
    outline: none;
    background: tomato;
    color: white;
    padding: 10px 18px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s ease;
    box-shadow: 0 4px 12px rgba(255,99,71,0.4);
}

.add-btn:hover{
    transform: scale(1.08);
}

/* Counter */
.food-item-counter{
    position: absolute;
    bottom: 15px;
    right: 15px;
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255,255,255,0.95);
    padding: 8px 12px;
    border-radius: 40px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.12);
}

.food-item-counter button{
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.food-item-counter img{
    width: 28px;
    transition: transform 0.2s ease;
}

.food-item-counter img:hover{
    transform: scale(1.15);
}

.food-item-counter p{
    font-size: 16px;
    font-weight: 600;
    min-width: 20px;
    text-align: center;
    color: #333;
}

/* Food Info */
.food-item-info{
    padding: 18px;
}

.food-item-name-rating{
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
}

.food-item-name-rating p{
    font-size: 20px;
    font-weight: 700;
    color: #222;
    font-family: sans-serif;
}

.food-item-name-rating img{
    width: 85px;
}

.food-item-desc{
    color: #777;
    font-size: 13px;
    line-height: 1.5;
    margin-top: 5px;
    font-family: sans-serif;
}

.food-item-price{
    color: tomato;
    font-size: 24px;
    font-weight: 700;
    margin-top: 14px;
    font-family: sans-serif;
}

/* Fade Animation */
@keyframes fadeIn{
    from{
        opacity: 0;
        transform: translateY(20px);
    }
    to{
        opacity: 1;
        transform: translateY(0);
    }
}

/* Responsive */
@media (max-width: 768px){

    .food-item{
        max-width: 100%;
    }

    .food-item-image{
        height: 220px;
    }

    .food-item-price{
        font-size: 20px;
    }

    .food-item-name-rating p{
        font-size: 18px;
    }
}